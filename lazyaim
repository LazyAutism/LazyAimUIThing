local activeHighlight = nil

local function applyHighlight(model)
    if activeHighlight then
        activeHighlight:Destroy()
        activeHighlight = nil
    end
    if not highlightEnabled or not model then return end
    local hl = Instance.new("SelectionBox")
    hl.Adornee = model
    hl.Color3 = Color3.fromRGB(255, 0, 0)
    hl.LineThickness = 0.05
    hl.SurfaceTransparency = (highlightStyle == 2) and 1 or 0.5
    hl.SurfaceColor3 = Color3.fromRGB(255, 0, 0)
    if highlightStyle == 3 then
        hl.LineThickness = 0
    end
    hl.Parent = gui
    activeHighlight = hl
end

local function clearHighlight()
    if activeHighlight then
        activeHighlight:Destroy()
        activeHighlight = nil
    end
end

