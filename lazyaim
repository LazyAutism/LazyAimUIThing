task.spawn(function()
    if introEnabled then
        -- Full intro animation
        frame.BackgroundTransparency = 1
        frame.Position = UDim2.new(0.5, -130, 0.5, -130)
        title.TextTransparency = 1
        subTitle.TextTransparency = 1
        ver.TextTransparency = 1
        title.Position = UDim2.new(0, 5, 0.35, 0)
        title.Size = UDim2.new(1, 0, 0, 50)
        ver.Position = UDim2.new(0.1, 0, 0.4, 0)
        ver.Size = UDim2.new(0.8, 0, 0, 60)

        TweenService:Create(frame, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
        task.wait(0.5)
        TweenService:Create(title, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
        task.wait(0.3)
        TweenService:Create(subTitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
        task.wait(1)
        TweenService:Create(subTitle, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        task.wait(0.3)
        TweenService:Create(ver, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
        task.wait(0.8)

        TweenService:Create(title, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {
            Position = UDim2.new(0, 5, 0, 0),
            Size = UDim2.new(1, -45, 0, 45)
        }):Play()
        TweenService:Create(ver, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {
            Position = UDim2.new(0, 0, 1, -25),
            Size = UDim2.new(1, 0, 0, 25)
        }):Play()
        TweenService:Create(frame, TweenInfo.new(0.8, Enum.EasingStyle.Quart), {
            Position = frameHomePos
        }):Play()
        task.wait(0.8)
    else
        -- Skip intro: snap straight to final state
        frame.BackgroundTransparency = 0
        frame.Position = frameHomePos
        title.TextTransparency = 0
        title.Position = UDim2.new(0, 5, 0, 0)
        title.Size = UDim2.new(1, -45, 0, 45)
        ver.TextTransparency = 0
        ver.Position = UDim2.new(0, 0, 1, -25)
        ver.Size = UDim2.new(1, 0, 0, 25)
        subTitle.TextTransparency = 1
    end

    content.Visible = true

    local h = 0
    RunService.RenderStepped:Connect(function()
        h = (h + 0.005) % 1
        ver.TextColor3 = Color3.fromHSV(h, 1, 1)
        if lockEnabled and lockedPart and lockedPart.Parent then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, lockedPart.Position)
        end
    end)
end)

