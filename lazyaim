local function updateWhitelistUI()
    for _, v in ipairs(wlList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = createButton(wlList, p.Name)
            pBtn.Size = UDim2.new(1, 0, 0, 30)
            pBtn.BackgroundColor3 = whitelist[p.UserId] and Color3.fromRGB(100, 0, 0) or Color3.fromRGB(30, 30, 30)
            pBtn.MouseButton1Click:Connect(function()
                whitelist[p.UserId] = not whitelist[p.UserId]
                pBtn.BackgroundColor3 = whitelist[p.UserId] and Color3.fromRGB(100, 0, 0) or Color3.fromRGB(30, 30, 30)
            end)
        end
    end
end
