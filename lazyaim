--========================================================--
--===================== AIM LOGIC ========================--
--========================================================--

local function clearLock()
    lockEnabled = false
    lockedPart = nil
    if deathConn then deathConn:Disconnect() deathConn = nil end
    if ancestryConn then ancestryConn:Disconnect() ancestryConn = nil end
end

local function getAimPart(model)
    if aimHead then
        return model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
    end
    return model:FindFirstChild("HumanoidRootPart")
end

local function validModel(model)
    if not model:IsA("Model") or model.Name == player.Name then return false end
    local targetPlayer = Players:GetPlayerFromCharacter(model)
    if isWhitelisted(targetPlayer) then return false end

    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    local isPlayer = (targetPlayer ~= nil)
    if filterIndex == 2 and not isPlayer then return false end
    if filterIndex == 3 and (not isPlayer or targetPlayer.Team == player.Team) then return false end
    if filterIndex == 4 and (not isPlayer or targetPlayer.Team ~= player.Team) then return false end
    if filterIndex == 5 and isPlayer then return false end
    return true
end

local function findTarget(forceMode)
    local best, bestDist = nil, math.huge
    local useMode = forceMode or modeIndex
    for _, model in ipairs(workspace:GetDescendants()) do
        if validModel(model) then
            local part = getAimPart(model)
            if part then
                if useMode == 1 then
                    if mouse.Target and mouse.Target:IsDescendantOf(model) then return part end
                elseif useMode == 2 then
                    local sp, _ = Camera:WorldToScreenPoint(part.Position)
                    local d = (Vector2.new(sp.X, sp.Y) - UIS:GetMouseLocation()).Magnitude
                    if d < bestDist then bestDist, best = d, part end
                elseif useMode == 3 and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local d = (part.Position - hrp.Position).Magnitude
                        if d < bestDist then bestDist, best = d, part end
                    end
                end
            end
        end
    end
    return best
end

local function lock(part)
    if not part then return end
    clearLock()
    lockedPart = part
    lockEnabled = true
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if hum then
        deathConn = hum.Died:Connect(function()
            clearLock()
            if autoRelock then
                local nextT = findTarget(2)
                if nextT then lock(nextT) end
            end
        end)
    end
    ancestryConn = part.AncestryChanged:Connect(function(_, p) if not p then clearLock() end end)
end

