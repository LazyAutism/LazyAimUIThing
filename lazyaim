UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if waitingFor then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            if waitingFor == "aim" then aimBind = input.KeyCode aimBindBtn.Text = "Aimlock Bind: "..aimBind.Name
            else uiBind = input.KeyCode uiBindBtn.Text = "UI Bind: "..uiBind.Name end
            waitingFor = nil attemptSave()
        end
        return
    end
    if input.KeyCode == aimBind and bindEnabled then
        if lockEnabled then clearLock() else lock(findTarget()) end
    end
    if input.KeyCode == uiBind then frame.Visible = not frame.Visible end
end)

