--========================================================--
--==================== PERSISTENCE =======================--
--========================================================--

local function persist()
    saveSettings({
        aimBind = aimBind.Name,
        uiBind = uiBind.Name,
        modeIndex = modeIndex,
        aimHead = aimHead,
        bindEnabled = bindEnabled,
        autoRelock = autoRelock,
        filterIndex = filterIndex,
        whitelistMode = whitelistMode,
        saveModeIndex = saveModeIndex
    })
end

local function attemptSave()
    if saveModeIndex == 1 then persist() end
end

-- Timed Loop
task.spawn(function()
    while task.wait(1) do
        local interval = ({0, 5, 10, 30})[saveModeIndex] or 0
        if interval > 0 and (tick() - lastSaveTime) >= interval then
            persist()
            lastSaveTime = tick()
        end
    end
end)

local saved = loadSettings()
if saved then
    if saved.aimBind then aimBind = Enum.KeyCode[saved.aimBind] end
    if saved.uiBind then uiBind = Enum.KeyCode[saved.uiBind] end
    if saved.modeIndex then modeIndex = saved.modeIndex end
    if saved.aimHead ~= nil then aimHead = saved.aimHead end
    if saved.bindEnabled ~= nil then bindEnabled = saved.bindEnabled end
    if saved.autoRelock ~= nil then autoRelock = saved.autoRelock end
    if saved.filterIndex then filterIndex = saved.filterIndex end
    if saved.whitelistMode then whitelistMode = saved.whitelistMode end
    if saved.saveModeIndex then saveModeIndex = saved.saveModeIndex end
end

-- Update UI
