--========================================================--
--===================== AIM LOGIC ========================--
--========================================================--

local function clearLock()
    lockEnabled = false
    lockedPart = nil
    clearHighlight()
    if deathConn then deathConn:Disconnect() deathConn = nil end
    if ancestryConn then ancestryConn:Disconnect() ancestryConn = nil end
end

local function getAimPart(model)
    if aimHead then
        return model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
    end
    return model:FindFirstChild("HumanoidRootPart")
end

local function validModel(model)
    if not model:IsA("Model") or model.Name == player.Name then return false end
    local targetPlayer = Players:GetPlayerFromCharacter(model)
    if isWhitelisted(targetPlayer) then return false end

    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    local isPlayer = (targetPlayer ~= nil)
    if filterIndex == 2 and not isPlayer then return false end
    if filterIndex == 3 and (not isPlayer or targetPlayer.Team == player.Team) then return false end
    if filterIndex == 4 and (not isPlayer or targetPlayer.Team ~= player.Team) then return false end
    if filterIndex == 5 and isPlayer then return false end
    return true
end

-- Fix for shiftlock/first person/mouse lock: use ViewportPointToRay and screen center
local function getScreenCenter()
    local vp = Camera.ViewportSize
    return Vector2.new(vp.X / 2, vp.Y / 2)
end

local function getMouseScreenPos()
    -- UIS:GetMouseLocation() works correctly even in shiftlock/first person,
    -- whereas mouse.X/Y can be locked to center in those modes.
    return UIS:GetMouseLocation()
end

local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen
end

local function findTarget(forceMode)
    local best, bestDist = nil, math.huge
    local useMode = forceMode or modeIndex
    for _, model in ipairs(workspace:GetDescendants()) do
        if validModel(model) then
            local part = getAimPart(model)
            if part then
                if useMode == 1 then
                    -- Direct mode: use ray from camera through screen center (fixes mouse lock)
                    local ray = Camera:ViewportPointToRay(getMouseScreenPos().X, getMouseScreenPos().Y)
                    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000)
                    if result and result.Instance and result.Instance:IsDescendantOf(model) then
                        return part
                    end
                elseif useMode == 2 then
                    -- Nearest to cursor: use ViewportPoint instead of mouse.X/Y
                    local sp, onScreen = worldToScreen(part.Position)
                    if onScreen then
                        local d = (sp - getMouseScreenPos()).Magnitude
                        if d < bestDist then bestDist, best = d, part end
                    end
                elseif useMode == 3 and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local d = (part.Position - hrp.Position).Magnitude
                        if d < bestDist then bestDist, best = d, part end
                    end
                end
            end
        end
    end
    return best
end

local function lock(part)
    if not part then return end
    clearLock()
    lockedPart = part
    lockEnabled = true
    applyHighlight(part.Parent)
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if hum then
        deathConn = hum.Died:Connect(function()
            clearLock()
            if autoRelock then
                local nextT = findTarget(2)
                if nextT then lock(nextT) end
            end
        end)
    end
    ancestryConn = part.AncestryChanged:Connect(function(_, p)
        if not p then clearLock() end
    end)
end

--========================================================--
--=================== UI SHOW/HIDE =======================--
--========================================================--

local frameHomePos = UDim2.new(0, 20, 0, 20)

local function showUI()
    uiVisible = true
    frame.Visible = true
    if hideAnimation then
        frame.Position = UDim2.new(0, 20, -0.5, 0)
        TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = frameHomePos
        }):Play()
    end
end

local function hideUI()
    uiVisible = false
    if hideAnimation then
        local tween = TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, 20, -0.5, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            if not uiVisible then frame.Visible = false end
        end)
    else
        frame.Visible = false
    end
end

